# Copy this file to .env.local for local dev, and set the same vars in Vercel for prod.

# Required — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# OPTIONAL — Pre-created Stripe Price IDs (recommended for production).
# Create products + prices in https://dashboard.stripe.com/products, then paste the IDs here.
# If a value is unset, the API route falls back to inline price_data with the early-bird
# discount calculated server-side.
STRIPE_PRICE_BASIC=
STRIPE_PRICE_SPOUSE=
STRIPE_PRICE_STUDENT=
STRIPE_PRICE_TEEN=
STRIPE_PRICE_WORKSHOP=
STRIPE_PRICE_LIVESTREAM=

# OPTIONAL — Stripe Coupon IDs for each early-bird tier (only needed if using pre-created prices).
# Create coupons in https://dashboard.stripe.com/coupons:
#   FOUNDERS25  → 25% off
#   EARLYBIRD20 → 20% off
#   FINAL15     → 15% off
STRIPE_COUPON_25=FOUNDERS25
STRIPE_COUPON_20=EARLYBIRD20
STRIPE_COUPON_15=FINAL15
